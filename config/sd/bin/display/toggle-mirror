#!/usr/bin/env bash
set -e

# toggles external-display mirroring via hammerspoon's direct coregraphics api.
# the logic lives in .hammerspoon/display_mirror.lua; this just calls it over
# the `hs` cli. no system settings window, no ui scripting.
# requires a running Hammerspoon with hs.ipc loaded and `hs` on PATH.

if ! command -v hs >/dev/null 2>&1; then
    echo "hs cli not found (install via hs.ipc.cliInstall)" >&2
    exit 1
fi

exec hs -c 'return require("display_mirror").toggle()'
