#!/usr/bin/env osascript

-- toggles mirroring between the built-in display and the external display
-- by ui-scripting system settings > displays.

on run
	-- ensure a clean start: system settings ignores url-scheme pane switches
	-- when it's already running with another pane visible.
	try
		tell application "System Settings" to quit
	end try
	delay 0.3

	do shell script "open 'x-apple.systempreferences:com.apple.Displays-Settings.extension'"
	tell application "System Settings" to activate

	-- wait for the Displays pane to actually appear.
	set thumbArea to missing value
	repeat with i from 1 to 40
		delay 0.2
		try
			tell application "System Events"
				tell process "System Settings"
					set thumbArea to my findScrollByDesc(window 1, "Displays")
				end tell
			end tell
		on error errMsg
			-- window may not exist yet; keep polling. save last error for diagnosis.
			set lastErr to errMsg
		end try
		if thumbArea is not missing value then exit repeat
	end repeat

	-- fallback: click the "Displays" row in the sidebar.
	if thumbArea is missing value then
		try
			tell application "System Events"
				tell process "System Settings"
					click (first static text of outline 1 of scroll area 1 of group 1 of splitter group 1 of group 1 of window 1 whose value is "Displays")
				end tell
			end tell
			repeat with i from 1 to 30
				delay 0.15
				try
					tell application "System Events"
						tell process "System Settings"
							set thumbArea to my findScrollByDesc(window 1, "Displays")
						end tell
					end tell
					if thumbArea is not missing value then exit repeat
				end try
			end repeat
		end try
	end if

	tell application "System Events"
		tell process "System Settings"
			set frontmost to true

			if thumbArea is missing value then
				-- dump the ui tree to /tmp so we can see what description the scroll area uses now.
				try
					set treeText to my dumpTree(window 1, "", 0)
					do shell script "cat > /tmp/toggle-mirror-tree.txt <<'EOF'
" & treeText & "
EOF"
				end try
				display notification "thumbnail area not found — tree at /tmp/toggle-mirror-tree.txt" with title "toggle-mirror"
				return
			end if

			-- the "Use as" popup on either detail pane offers Main / Extended / Mirror-for options,
			-- so just flip whichever pane is currently showing.
			set detailArea to my findScrollByDescPrefix(window 1, "Display settings for")
			set usePopup to missing value
			try
				-- popup sits right after the "Use as" label in the first group.
				set usePopup to first pop up button of group 1 of detailArea
			end try
			if usePopup is missing value then
				display notification "'Use as' popup not found" with title "toggle-mirror"
				return
			end if

			set currentValue to (value of usePopup as string)
			click usePopup
			delay 0.25

			-- flip main <-> mirror. preserves the currently-selected display's role.
			set targetPrefix to "Mirror"
			if currentValue starts with "Mirror" then set targetPrefix to "Main"

			set picked to false
			repeat with mi in menu items of menu 1 of usePopup
				try
					set nm to (name of mi as string)
					if nm starts with targetPrefix then
						click mi
						set picked to true
						exit repeat
					end if
				end try
			end repeat

			if not picked then
				-- close the menu if we could not find a target.
				key code 53 -- escape
				display notification "could not find '" & targetPrefix & "' menu item" with title "toggle-mirror"
				return
			end if
		end tell
	end tell

	delay 0.3
	tell application "System Settings" to quit
end run

on findScrollByDesc(root, targetDesc)
	tell application "System Events"
		set allEls to entire contents of root
		repeat with el in allEls
			try
				if (role of el as string) is "AXScrollArea" and (description of el as string) is targetDesc then
					return contents of el
				end if
			end try
		end repeat
	end tell
	return missing value
end findScrollByDesc

on findScrollByDescPrefix(root, prefix)
	tell application "System Events"
		set allEls to entire contents of root
		repeat with el in allEls
			try
				if (role of el as string) is "AXScrollArea" and ((description of el as string) starts with prefix) then
					return contents of el
				end if
			end try
		end repeat
	end tell
	return missing value
end findScrollByDescPrefix

on dumpTree(el, path, depth)
	set out to ""
	if depth > 12 then return out
	tell application "System Events"
		try
			set r to role of el as string
		on error
			set r to "?"
		end try
		try
			set d to description of el as string
		on error
			set d to ""
		end try
		try
			set v to value of el as string
		on error
			set v to ""
		end try
	end tell
	set out to out & path & " [" & r & "] val=" & v & " desc=" & d & linefeed
	try
		tell application "System Events" to set subs to UI elements of el
		set i to 0
		repeat with c in subs
			set i to i + 1
			set out to out & my dumpTree(c, path & "/" & i, depth + 1)
		end repeat
	end try
	return out
end dumpTree
