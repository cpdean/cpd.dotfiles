#!/usr/bin/env bash
# suggests a PR title from the current git branch name.
# branches that start with 'XXX-DDD-...' get a JIRA-style prefix:
#   cards-338-doing-stuff  ->  [CARDS-338] Doing Stuff
# branches without that pattern just get title-cased:
#   doing-stuff            ->  Doing Stuff

set -euo pipefail

branch=$(git rev-parse --abbrev-ref HEAD)

title_case() {
    awk '{
        for (i=1; i<=NF; i++) {
            $i = toupper(substr($i,1,1)) tolower(substr($i,2))
        }
        print
    }'
}

if [[ "$branch" =~ ^([a-zA-Z]+)-([0-9]+)-(.*)$ ]]; then
    project="${BASH_REMATCH[1]}"
    number="${BASH_REMATCH[2]}"
    rest="${BASH_REMATCH[3]}"
    project_upper=$(echo "$project" | tr '[:lower:]' '[:upper:]')
    rest_title=$(echo "$rest" | tr -- '-_' '  ' | title_case)
    echo "[${project_upper}-${number}] ${rest_title}"
else
    echo "$branch" | tr -- '-_' '  ' | title_case
fi
